# ─────────────────────────────────────────────────────────
#  RMS Frontend – Development Environment Variables
#
#  Vite only exposes vars prefixed with VITE_ to the browser bundle.
#  Do NOT put secrets here.
# ─────────────────────────────────────────────────────────

# Relative path routes through Vite's built-in reverse proxy (vite.config.js).
# The proxy forwards /api/* → http://localhost:5000, so no CORS issues in dev.
#VITE_API_URL=http://localhost:5000/api/v1

# Vite dev server origin – the /socket.io WS proxy in vite.config.js will
# upgrade the WebSocket connection to the backend automatically.
VITE_SOCKET_URL=http://localhost:5000/api/v1
